  "keyFeatures": [
    "User and service management with role-based permissions",
    "Template creation and management for email, SMS, and letters",
    "Batch notification sending via CSV upload",
    "Real-time dashboard with notification history and statistics",
    "Multi-factor authentication including WebAuthn support",
    "Organization management with team hierarchies",
    "API key generation and management",
    "Branding customization for emails and letters"
